@{
    ViewBag.Title = "Solicitar cambio de Cliente";
}

<h2>📨 Solicitar cambio — Cliente</h2>
<a asp-controller="Cliente" asp-action="Index" class="btn btn-secondary mb-3">← Volver</a>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">@Html.ValidationSummary(false)</div>
}

<div class="card" style="max-width:600px;">
    <div class="card-body p-4">
        <h6 class="text-muted">Datos actuales</h6>
        <p class="border rounded p-3 bg-light">@ViewBag.DatosActuales</p>

        <form asp-action="SolicitarCliente" asp-route-id="@Context.Request.RouteValues["id"]" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="form-label">¿Qué necesitas cambiar?</label>
                <textarea name="cambioPropuesto" class="form-control" rows="4" required
                          placeholder="Ej: El nombre correcto es 'Juan Pérez', no 'Juan Peres'"></textarea>
            </div>
            <button type="submit" class="btn btn-primary w-100">Enviar solicitud al Director de Operaciones</button>
        </form>
    </div>
</div>