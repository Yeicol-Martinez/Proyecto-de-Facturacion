@model FacturacionApp.Models.Factura
@{
    ViewData["Title"] = "Nueva Factura";
    var productos = (List<FacturacionApp.Models.Producto>)ViewBag.Productos;
}

<h2>🧾 Nueva Factura</h2>
<hr />

<form asp-action="Create" method="post" id="formFactura">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="alert alert-danger"></div>

    <div class="row g-3 mb-4">
        <!-- Datos de cabecera -->
        <div class="col-md-5">
            <label asp-for="ClienteId" class="form-label fw-bold">Cliente *</label>
            <select asp-for="ClienteId" class="form-select" asp-items="ViewBag.ClienteId">
                <option value="">-- Selecciona un cliente --</option>
            </select>
            <span asp-validation-for="ClienteId" class="text-danger"></span>
        </div>
        <div class="col-md-3">
            <label asp-for="FechaEmision" class="form-label fw-bold">Fecha Emisión *</label>
            <input asp-for="FechaEmision" class="form-control" type="date" />
            <span asp-validation-for="FechaEmision" class="text-danger"></span>
        </div>
        <div class="col-md-3">
            <label asp-for="FechaVencimiento" class="form-label fw-bold">Vencimiento</label>
            <input asp-for="FechaVencimiento" class="form-control" type="date" />
        </div>
        <div class="col-md-12">
            <label asp-for="Observaciones" class="form-label fw-bold">Observaciones</label>
            <textarea asp-for="Observaciones" class="form-control" rows="1" placeholder="Notas adicionales..."></textarea>
        </div>
    </div>

    <!-- Líneas de detalle -->
    <div class="card shadow mb-3">
        <div class="card-header bg-dark text-white fw-bold d-flex justify-content-between align-items-center">
            <span>📋 Detalle de Productos</span>
            <button type="button" class="btn btn-success btn-sm" onclick="agregarFila()">➕ Agregar Producto</button>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-bordered mb-0 align-middle" id="tablaDetalle">
                    <thead class="table-secondary">
                        <tr>
                            <th style="width:35%">Producto</th>
                            <th style="width:10%">Cant.</th>
                            <th style="width:15%">Precio Unit.</th>
                            <th style="width:10%">ITBIS %</th>
                            <th style="width:12%">Subtotal</th>
                            <th style="width:12%">Total Línea</th>
                            <th style="width:6%"></th>
                        </tr>
                    </thead>
                    <tbody id="filas">
                        <!-- Filas dinámicas -->
                    </tbody>
                    <tfoot>
                        <tr class="table-light">
                            <td colspan="4" class="text-end fw-bold">Subtotal:</td>
                            <td id="totalSubtotal" class="fw-bold">RD$ 0.00</td>
                            <td colspan="2"></td>
                        </tr>
                        <tr class="table-light">
                            <td colspan="4" class="text-end fw-bold">ITBIS:</td>
                            <td id="totalItbis" class="fw-bold text-warning">RD$ 0.00</td>
                            <td colspan="2"></td>
                        </tr>
                        <tr class="table-success">
                            <td colspan="4" class="text-end fw-bold fs-5">TOTAL:</td>
                            <td id="totalGeneral" class="fw-bold fs-5">RD$ 0.00</td>
                            <td colspan="2"></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>

    <div id="errorDetalle" class="alert alert-danger d-none">❌ Debe agregar al menos un producto.</div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-success btn-lg" onclick="return validarDetalle()">💾 Emitir Factura</button>
        <a asp-action="Index" class="btn btn-secondary btn-lg">⬅ Cancelar</a>
    </div>
</form>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
        // Datos de productos cargados desde el servidor
        const productos = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
            productos.Select(p => new { id = p.Id, nombre = p.Nombre, precio = p.PrecioUnitario, itbis = p.Itbis })
        ));

        let filaIndex = 0;

        function agregarFila() {
            const tbody = document.getElementById('filas');
            const opts = productos.map(p => `<option value="${p.id}" data-precio="${p.precio}" data-itbis="${p.itbis}">${p.nombre}</option>`).join('');
            const fila = `
            <tr id="fila_${filaIndex}">
                <td>
                    <select name="productoIds" class="form-select form-select-sm" onchange="actualizarFila(${filaIndex})">
                        <option value="">-- Seleccionar --</option>
                        ${opts}
                    </select>
                </td>
                <td><input type="number" name="cantidades" class="form-control form-control-sm" value="1" min="1" onchange="calcularTotales()" id="cant_${filaIndex}" /></td>
                <td><input type="text" class="form-control form-control-sm" readonly id="precio_${filaIndex}" value="0.00" /></td>
                <td><input type="text" class="form-control form-control-sm" readonly id="itbis_${filaIndex}" value="0%" /></td>
                <td id="sub_${filaIndex}" class="text-end">RD$ 0.00</td>
                <td id="tot_${filaIndex}" class="text-end fw-bold">RD$ 0.00</td>
                <td><button type="button" class="btn btn-danger btn-sm" onclick="eliminarFila(${filaIndex})">✖</button></td>
            </tr>`;
            tbody.insertAdjacentHTML('beforeend', fila);
            filaIndex++;
        }

        function eliminarFila(idx) {
            document.getElementById(`fila_${idx}`)?.remove();
            calcularTotales();
        }

        function actualizarFila(idx) {
            const sel = document.querySelector(`#fila_${idx} select`);
            const opt = sel.options[sel.selectedIndex];
            const precio = parseFloat(opt.dataset.precio || 0);
            const itbis  = parseFloat(opt.dataset.itbis  || 0);
            document.getElementById(`precio_${idx}`).value = precio.toFixed(2);
            document.getElementById(`itbis_${idx}`).value  = itbis + '%';
            calcularTotales();
        }

        function calcularTotales() {
            let subtotal = 0, totalItbis = 0;
            const filas = document.querySelectorAll('#filas tr');
            filas.forEach(fila => {
                const id = fila.id?.replace('fila_','');
                if (id === undefined) return;
                const sel   = fila.querySelector('select');
                const cant  = parseFloat(fila.querySelector('input[name="cantidades"]')?.value || 0);
                const prec  = parseFloat(document.getElementById(`precio_${id}`)?.value || 0);
                const itbisP = parseFloat(document.getElementById(`itbis_${id}`)?.value?.replace('%','') || 0);
                const sub   = cant * prec;
                const itb   = sub * (itbisP / 100);
                const tot   = sub + itb;
                if (document.getElementById(`sub_${id}`)) document.getElementById(`sub_${id}`).innerText = 'RD$ ' + sub.toFixed(2);
                if (document.getElementById(`tot_${id}`)) document.getElementById(`tot_${id}`).innerText = 'RD$ ' + tot.toFixed(2);
                subtotal   += sub;
                totalItbis += itb;
            });
            document.getElementById('totalSubtotal').innerText = 'RD$ ' + subtotal.toFixed(2);
            document.getElementById('totalItbis').innerText    = 'RD$ ' + totalItbis.toFixed(2);
            document.getElementById('totalGeneral').innerText  = 'RD$ ' + (subtotal + totalItbis).toFixed(2);
        }

        function validarDetalle() {
            const filas = document.querySelectorAll('#filas tr');
            if (filas.length === 0) {
                document.getElementById('errorDetalle').classList.remove('d-none');
                return false;
            }
            document.getElementById('errorDetalle').classList.add('d-none');
            return true;
        }

        // Agregar una fila inicial
        agregarFila();
    </script>
}
