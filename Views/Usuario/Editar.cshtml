@model FacturacionApp.Models.UsuarioViewModel

@{
    ViewBag.Title = "Editar Usuario";
}

<h2>✏️ Editar Usuario</h2>
<a asp-action="Index" class="btn btn-secondary mb-3">← Volver</a>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        @Html.ValidationSummary(false)
    </div>
}

<div class="card" style="max-width:500px;">
    <div class="card-body p-4">
        <form asp-action="Editar" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label class="form-label">Nombre completo</label>
                <input type="text" name="nombreCompleto" class="form-control"
                       value="@Model.NombreCompleto" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Correo electrónico</label>
                <input type="email" class="form-control" value="@Model.Email" disabled />
                <small class="text-muted">El correo no se puede modificar.</small>
            </div>

            <div class="mb-3">
                <label class="form-label">Rol</label>
                <select name="rol" class="form-select" required>
                    @foreach (var r in (ViewBag.Roles as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>) ?? Enumerable.Empty<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>())
                    {
                        if (r.Selected)
                        {
                            <option value="@r.Value" selected="selected">@r.Text</option>
                        }
                        else
                        {
                            <option value="@r.Value">@r.Text</option>
                        }
                    }
                </select>
            </div>

            <button type="submit" class="btn btn-warning w-100">Guardar cambios</button>
        </form>
    </div>
</div>