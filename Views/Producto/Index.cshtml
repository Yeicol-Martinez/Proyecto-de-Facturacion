@model IEnumerable<FacturacionApp.Models.Producto>
@{
    ViewData["Title"] = "Productos";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>📦 Productos</h2>
    @if (User.IsInRole("Admin") || User.IsInRole("AuxiliarInventario"))
    {
        <a asp-action="Create" class="btn btn-success">➕ Nuevo Producto</a>
    }
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No hay productos registrados.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle shadow-sm">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Nombre</th>
                    <th>Descripción</th>
                    <th>Precio Unitario</th>
                    <th>ITBIS %</th>
                    <th>Stock</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td>@p.Id</td>
                        <td class="fw-bold">@p.Nombre</td>
                        <td class="text-muted small">@p.Descripcion</td>
                        <td>RD$ @p.PrecioUnitario.ToString("N2")</td>
                        <td>@p.Itbis%</td>
                        <td>
                            <span class="badge @(p.Stock > 0 ? "bg-success" : "bg-danger")">@p.Stock</span>
                        </td>
                        <td>
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary">✏️ Editar</a>
                                <form asp-action="Delete" asp-route-id="@p.Id" method="post" class="d-inline"
                                      onsubmit="return confirm('¿Eliminar producto @p.Nombre?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger">🗑️ Eliminar</button>
                                </form>
                            }
                            @if (User.IsInRole("AuxiliarInventario"))
                            {
                                <a asp-controller="Solicitud" asp-action="SolicitarProducto" asp-route-id="@p.Id" class="btn btn-sm btn-outline-warning">📨 Solicitar cambio</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
